{
  "name": "My App with Antigravity",
  "build": {
    "dockerfile": "Dockerfile"
  },
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode-remote.remote-containers"
      ],
      "settings": {
        "git.autofetch": true
      }
    }
  },
  "mounts": [
    // Antigravity
    "source=${localEnv:HOME}/.gemini,target=/home/vscode/.gemini,type=bind,consistency=cached,Z",
    // GIT credentials
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached,Z"
  ],

  "forwardPorts": [3000, 8080],

  // Optioneel: geef ze een mooie naam in de 'Ports' tab van VS Code
  "portsAttributes": {
    "3000": {
      "label": "Application Webserver",
      "onAutoForward": "notify"
    }
  },

  
  "remoteUser": "vscode",
  "containerUser": "vscode",
  "updateRemoteUserUID": true,
  // "postStartCommand": "sudo chown -R vscode:vscode /home/vscode/.gemini",
  
  "postCreateCommand": "bash .devcontainer/post-create.sh"
}